{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:8080",

  "Storage": {
    "DatabasePath": "data/infrawatch.db"
  },

  "HostNet": {
    "Interval": "00:01:00",
    "PingWarnMs": 150,
    "PingTargets": [ "localhost", "8.8.8.8" ],
    "TlsTargets": [ "sscserv.atlassian.net:443", "github.com:443" ],
    "CertWarnDays": 30,
    "CertCriticalDays": 7
  },

  "Jira": {
    "BaseUrl": "https://sscserv.atlassian.net",
    "Email": "",
    "ApiToken": "",
    "Projects": [ "IMS", "CHG", "CSI" ],
    "Interval": "00:05:00",
    "UnansweredAgeHours": 24,
    "Timeclock": {
      "Keywords": [ "timeclock", "time clock" ],
      "AlertWhenOpen": true
    }
  }
}
